# Copy to terraform.tfvars and edit. terraform.tfvars is gitignored.

# ---- Proxmox connection ----
proxmox_endpoint     = "https://192.168.1.10:8006"
proxmox_api_token    = "terraform@pve!tf=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
proxmox_insecure     = true
proxmox_ssh_username = "root"
node_name            = "pve"
datastore_id         = "local-lvm"
snippet_datastore_id = "local"

# ---- Bridges ----
wan_bridge = "vmbr0"   # internet from the host
lan_bridge = "vmbr1"   # MUST be VLAN-aware (see README)

# ---- Templates (built earlier) ----
vyos_template_id   = 9000
ubuntu_template_id = 9001
debian_template_id = 9002

# ---- VyOS WAN ----
# Static is recommended so the SSH port-forward target is predictable.
# ADJUST to a free address + gateway on your host LAN (pve is 192.168.1.10).
wan_address = "192.168.1.2/24"
wan_gateway = "192.168.1.1"
# Or, to take whatever the host hands out:
# wan_address = "dhcp"
# wan_gateway = ""

# ---- Access ----
# Your mac's public key — authorized on control + VyOS. REQUIRED.
workstation_public_key = "ssh-ed25519 AAAA...replace-me... you@mac"

# Reach control from the mac:  ssh -p 2201 v2e@192.168.1.2
control_ssh_wan_port = 2201

# Set true to also put your mac key on services + agent (default: reach them via control).
authorize_workstation_on_all_nodes = false

# ---- Logins ----
# primary admin mesh (hub = control): v2e@control reaches services, agent, vyos
cluster_user     = "v2e"
sudo_password    = ""
# automation mesh (hub = control): ansible@control reaches every node + the router.
ansible_user     = "ansible"

# ---- VyOS router login ----
# The router comes up with the default 'vyos' user, authorized for your mac key +
# both mesh keys, so Ansible can SSH in (vyos@10.1.1.1) and take over router
# config — including provisioning dedicated router users. OPTIONAL: a sha-512
# console password for that bootstrap user (else image default vyos/vyos):
#   openssl passwd -6 'yourpass'
# router_password_hash = "$6$..."

# ---- Sizing (optional overrides) ----
# vyos_memory   = 1024
# node_memory   = 2048
# node_disk_size = 20

# Give VyOS longer to boot+route on a slow host before the nodes come up.
router_boot_wait = "120s"

# Extra raw VyOS commands, e.g. a DNS forwarder or time zone:
extra_vyos_commands = [
  # "set system time-zone 'Europe/Amsterdam'",
]

# ---- Firewall ----
# Default-deny boundary applied when the router is built (set false to disable).
# firewall_enabled = true
# CIDRs allowed to SSH the ROUTER itself over the WAN. Empty = none (reach the
# router via control). Does not affect the control DNAT (WAN:2201 -> control:22).
trusted_mgmt_sources = [] # e.g. ["203.0.113.5/32"]

# ---- Cloudflare tunnel (OPTIONAL) ----
# Leave these three BLANK to skip Cloudflare entirely; the rest of the lab
# deploys unchanged. Set ALL THREE to bring up a key-auth SSH tunnel to control
# (cloudflared installed on control at first boot). Zero Trust / OTP is added
# later via Ansible, not here. Requires the domain already on Cloudflare.
# Token scopes: Account>Cloudflare Tunnel:Edit, Zone>DNS:Edit, Zone>Zone:Read.
cloudflare_api_token  = "" # blank = tunnel disabled
cloudflare_account_id = ""
cloudflare_zone_id    = ""

# Hostname routed to control's sshd (defaults shown; override for your domain).
tunnel_hostname = "lab.v2e.sh"
tunnel_dns_name = "lab"
# tunnel_name   = "v2e-control-ssh"

# ---- Ansible bootstrap ----
# ON by default: control (mesh hub) clones the PUBLIC repo on first boot and runs
# the playbook against the whole mesh over its existing v2e SSH trust. Inventory
# hosts must be reachable from control as v2e — use the ssh aliases (services,
# agent) or their IPs. Set ansible_repo_url = "" to disable.
ansible_repo_url  = "https://github.com/v2e-sh/v2e-ansible"
ansible_repo_ref  = "608af5ff8e0dbc4c0fc871f50663bab08dbb255a" # pin to a commit/tag; bump on new releases
ansible_playbook  = "site.yml"
ansible_inventory = "inventory/hosts.ini"
# ansible_version = "11.1.0"  # pin the pipx Ansible on control (empty = latest)

# Ansible Vault password — seeded to /home/ansible/.vault_pass on control so the
# bootstrap can decrypt vaulted vars. Blank = not seeded (Ansible runs without
# vault). WARNING: stored here AND in tf state in plaintext.
# ansible_vault_password = ""
