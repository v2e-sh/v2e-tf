# Local .terraform directories
**/.terraform/*
# .terraform.lock.hcl is committed on purpose (pinned provider versions)

# State files — contain secrets in plaintext, never commit
*.tfstate
*.tfstate.*
*.tfstate.backup

# Variable files with real values (commit terraform.tfvars.example instead)
*.tfvars
*.tfvars.json
!*.tfvars.example

# Crash / plan output
crash.log
crash.*.log
*.tfplan

# CLI config that may hold credentials
.terraformrc
terraform.rc

# macOS
.DS_Store

# Local secrets — NEVER commit. age private keys decrypt every SOPS secret.
keys.txt
keys-backup.txt
keys*.txt
.deploy-creds.txt
# SOPS file is encrypted (safe) but follow the "supply your own locally" model
secrets.sops.yaml
# Build/apply logs
*.log
